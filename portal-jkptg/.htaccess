# Hostinger root .htaccess — forwards all traffic to public/ since shared hosting
# typically lands at the project root. If Hostinger document root can be set
# directly to public/ (recommended), delete this file.

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
